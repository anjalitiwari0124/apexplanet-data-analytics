# -----------------------------------------------------------------------------
# BUSINESS QUESTION 10: Year-over-Year Growth
# -----------------------------------------------------------------------------
print("""
┌──────────────────────────────────────────────────────────────────────┐
│  Q10: What is the year-over-year growth rate?                        │
│  Purpose: Track business growth over time                            │
└──────────────────────────────────────────────────────────────────────┘
""")

q10_business = pd.read_sql("""
WITH yearly_sales AS (
    SELECT 
        Order_Year,
        SUM(Sales) as Total_Sales,
        SUM(Profit) as Total_Profit,
        COUNT(*) as Total_Orders
    FROM sales
    GROUP BY Order_Year
)
SELECT 
    Order_Year,
    Total_Sales,
    Total_Profit,
    Total_Orders,
    LAG(Total_Sales, 1) OVER (ORDER BY Order_Year) as Prev_Year_Sales,
    ROUND(
        ((Total_Sales - LAG(Total_Sales, 1) OVER (ORDER BY Order_Year)) 
         / LAG(Total_Sales, 1) OVER (ORDER BY Order_Year)) * 100, 2
    ) as YoY_Growth_Pct
FROM yearly_sales
ORDER BY Order_Year
""", conn)

print(q10_business.to_string(index=False))

# Visualize
fig, ax = plt.subplots(figsize=(10, 6))
ax.bar(q10_business['Order_Year'], q10_business['Total_Sales'], color='#3498DB', alpha=0.7, label='Total Sales')
ax2 = ax.twinx()
ax2.plot(q10_business['Order_Year'], q10_business['YoY_Growth_Pct'], color='#E74C3C', marker='o', 
         linewidth=2, markersize=8, label='YoY Growth %')
ax.set_xlabel('Year')
ax.set_ylabel('Total Sales ($)', color='#3498DB')
ax2.set_ylabel('YoY Growth (%)', color='#E74C3C')
ax.set_title('Q10: Year-over-Year Sales & Growth', fontweight='bold', fontsize=14)
ax.tick_params(axis='y', labelcolor='#3498DB')
ax2.tick_params(axis='y', labelcolor='#E74C3C')
plt.tight_layout()
plt.savefig('sql_q10_yoy_growth.png', dpi=150, bbox_inches='tight')
plt.show()
print("✅ Chart saved: sql_q10_yoy_growth.png")


