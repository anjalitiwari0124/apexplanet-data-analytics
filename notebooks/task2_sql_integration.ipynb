# ==============================================================================
# PART 1: SETUP - Import Libraries and Create Database
# ==============================================================================

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import sqlite3
import warnings
warnings.filterwarnings('ignore')

# Set style for better-looking charts
plt.style.use('seaborn-v0_8-whitegrid')
sns.set_palette("husl")

print("=" * 70)
print("STEP 1: SETUP COMPLETE")
print("=" * 70)
print("\n✅ Libraries imported:")
print("   • pandas - for data manipulation")
print("   • numpy - for numerical operations")
print("   • matplotlib - for static visualizations")
print("   • seaborn - for statistical visualizations")
print("   • sqlite3 - for database connection (built into Python!)")


# ==============================================================================
# STEP 2: CREATE DATABASE AND LOAD DATA
# ==============================================================================
# 
# WHAT IS SQLITE?
# SQLite is a lightweight database that stores everything in a single file.
# It's like Excel, but you interact with it using SQL commands.
# BEST PART: It's already built into Python - no installation needed!
#
# WHAT WE'RE DOING:
# 1. Create a database file (superstore.db)
# 2. Load our cleaned data from Task 1 into the database
# 3. The data becomes a "table" that we can query with SQL

print("\n" + "=" * 70)
print("STEP 2: CREATING DATABASE")
print("=" * 70)

# Create/connect to SQLite database
# This creates a file called 'superstore.db' in your folder
conn = sqlite3.connect('superstore.db')

# Load the cleaned dataset from Task 1
# If you don't have the CSV, you can use the synthetic data creation code from Task 1
try:
    df = pd.read_csv('superstore_cleaned.csv')
    print("\n✅ Loaded existing cleaned data from Task 1")
except FileNotFoundError:
    print("\n⚠️  Cleaned data not found. Please run Task 1 first to generate the data.")
    print("   Or create the dataset using the code from Task 1.")
    # You would add data creation code here

# Save data to SQLite database as a table called 'sales'
# if_exists='replace' means: if table exists, overwrite it
df.to_sql('sales', conn, if_exists='replace', index=False)

print(f"\n✅ Database created: superstore.db")
print(f"✅ Table 'sales' created with {len(df)} rows and {len(df.columns)} columns")

# Verify the table was created
# This SQL query counts the total number of rows
count_result = pd.read_sql("SELECT COUNT(*) as Total_Rows FROM sales", conn)
print(f"\n📊 Verification: Table contains {count_result['Total_Rows'].iloc[0]} rows")

# Show the column names
schema = pd.read_sql("PRAGMA table_info(sales)", conn)
print(f"\n📋 Table columns:")
for _, row in schema.iterrows():
    print(f"   • {row['name']} ({row['type']})")


# ==============================================================================
# STEP 3: CREATE HELPER FUNCTION
# ==============================================================================
# 
# This function makes it easy to run SQL and display results
# You don't need to understand this code - just use it!

def run_sql(query, description=""):
    """
    Run a SQL query and return results as a pandas DataFrame.

    Parameters:
        query (str): The SQL query to run
        description (str): A description of what the query does

    Returns:
        DataFrame: Query results
    """
    result = pd.read_sql(query, conn)
    print(f"\n{'─' * 70}")
    print(f"📌 QUERY: {description}")
    print(f"{'─' * 70}")
    print(f"SQL: {query.strip()}")
    print(f"\n📊 Result ({len(result)} rows):")
    print(result.to_string())
    return result

print("\n✅ Helper function 'run_sql()' created - use it to run any SQL query!")


# ==============================================================================
# PART 2: BASIC SQL QUERIES (Day 7-8)
# ==============================================================================

print("\n" + "=" * 70)
print("PART 2: BASIC SQL QUERIES")
print("=" * 70)

# -----------------------------------------------------------------------------
# QUERY 1: SELECT - View all data
# -----------------------------------------------------------------------------
# SELECT * means "show all columns"
# LIMIT 5 means "only show first 5 rows"
# Use this to quickly inspect your data

print("""
╔══════════════════════════════════════════════════════════════════════╗
║  QUERY 1: SELECT * - View all columns (first 5 rows)                ║
╠══════════════════════════════════════════════════════════════════════╣
║  SELECT = "Show me..."                                               ║
║  * = "everything/all columns"                                        ║
║  LIMIT 5 = "only show first 5 rows"                                  ║
╚══════════════════════════════════════════════════════════════════════╝
""")

q1 = run_sql("SELECT * FROM sales LIMIT 5", "View first 5 rows of all columns")


# -----------------------------------------------------------------------------
# QUERY 2: SELECT specific columns
# -----------------------------------------------------------------------------
# Instead of SELECT * (all columns), we can pick specific ones
# This is faster and cleaner when you don't need everything

print("""
╔══════════════════════════════════════════════════════════════════════╗
║  QUERY 2: SELECT specific columns                                    ║
╠══════════════════════════════════════════════════════════════════════╣
║  SELECT column1, column2, column3                                    ║
║  → "Show me only these specific columns"                             ║
╚══════════════════════════════════════════════════════════════════════╝
""")

q2 = run_sql("""
SELECT Order_ID, Customer_Name, Category, Sales, Profit 
FROM sales 
LIMIT 8
""", "Show only specific columns (first 8 rows)")


# -----------------------------------------------------------------------------
# QUERY 3: WHERE - Filter data
# -----------------------------------------------------------------------------
# WHERE = "Only show me rows WHERE this condition is true"
# Examples:
#   WHERE Sales > 10000    → Orders with sales over $10,000
#   WHERE Category = 'Technology' → Only Technology products
#   WHERE Profit < 0       → Loss-making orders

print("""
╔══════════════════════════════════════════════════════════════════════╗
║  QUERY 3: WHERE - Filter data                                        ║
╠══════════════════════════════════════════════════════════════════════╣
║  WHERE = "Only show me rows WHERE this condition is true"            ║
║                                                                      ║
║  Common operators:                                                   ║
║  =    equals                    >     greater than                   ║
║  !=   not equal                 <     less than                      ║
║  >=   greater than or equal     <=    less than or equal             ║
║  AND  both conditions true      OR    at least one true              ║
╚══════════════════════════════════════════════════════════════════════╝
""")

q3 = run_sql("""
SELECT Order_ID, Customer_Name, Category, Sales, Profit 
FROM sales 
WHERE Sales > 15000
ORDER BY Sales DESC
LIMIT 10
""", "Filter: Orders with Sales > $15,000 (Top 10)")


# -----------------------------------------------------------------------------
# QUERY 4: ORDER BY - Sort results
# -----------------------------------------------------------------------------
# ORDER BY = "Sort the results by this column"
# ORDER BY Sales DESC  → Highest sales first (Descending)
# ORDER BY Sales ASC   → Lowest sales first (Ascending)

print("""
╔══════════════════════════════════════════════════════════════════════╗
║  QUERY 4: ORDER BY - Sort results                                    ║
╠══════════════════════════════════════════════════════════════════════╣
║  ORDER BY column_name DESC → Highest to lowest (Z to A)             ║
║  ORDER BY column_name ASC  → Lowest to highest (A to Z)             ║
║  Default is ASC if not specified                                     ║
╚══════════════════════════════════════════════════════════════════════╝
""")

q4 = run_sql("""
SELECT Order_ID, Customer_Name, Category, Sales, Profit 
FROM sales 
ORDER BY Sales DESC
LIMIT 10
""", "Top 10 orders by Sales (highest to lowest)")


# -----------------------------------------------------------------------------
# QUERY 5: GROUP BY + Aggregate Functions
# -----------------------------------------------------------------------------
# GROUP BY = "Group rows that have the same values"
# Common aggregate functions:
#   SUM(column)   → Add up all values
#   AVG(column)   → Calculate average
#   COUNT(*)      → Count number of rows
#   MAX(column)   → Find maximum value
#   MIN(column)   → Find minimum value

print("""
╔══════════════════════════════════════════════════════════════════════╗
║  QUERY 5: GROUP BY + Aggregate Functions                             ║
╠══════════════════════════════════════════════════════════════════════╣
║  GROUP BY = "Group rows that have the same values"                   ║
║                                                                      ║
║  SUM(column)   → Add up all values                                   ║
║  AVG(column)   → Calculate average                                   ║
║  COUNT(*)      → Count number of rows                                ║
║  MAX(column)   → Find maximum value                                  ║
║  MIN(column)   → Find minimum value                                  ║
╚══════════════════════════════════════════════════════════════════════╝
""")

q5 = run_sql("""
SELECT 
    Category,
    COUNT(*) as Total_Orders,
    SUM(Sales) as Total_Sales,
    AVG(Sales) as Avg_Sales,
    SUM(Profit) as Total_Profit,
    AVG(Profit) as Avg_Profit
FROM sales 
GROUP BY Category
ORDER BY Total_Sales DESC
""", "Summary statistics by Category")


# -----------------------------------------------------------------------------
# QUERY 6: HAVING - Filter groups
# -----------------------------------------------------------------------------
# WHERE filters ROWS before grouping
# HAVING filters GROUPS after grouping
# Example: Show only states with more than 250 orders

print("""
╔══════════════════════════════════════════════════════════════════════╗
║  QUERY 6: HAVING - Filter Groups                                     ║
╠══════════════════════════════════════════════════════════════════════╣
║  WHERE = filters ROWS before grouping                                ║
║  HAVING = filters GROUPS after grouping                              ║
║                                                                      ║
║  Use HAVING when you want to filter based on aggregated values       ║
╚══════════════════════════════════════════════════════════════════════╝
""")

q6 = run_sql("""
SELECT 
    State,
    COUNT(*) as Total_Orders,
    SUM(Sales) as Total_Sales
FROM sales 
GROUP BY State
HAVING COUNT(*) > 250
ORDER BY Total_Sales DESC
""", "States with more than 250 orders")


# -----------------------------------------------------------------------------
# QUERY 7: JOIN - Combine tables
# -----------------------------------------------------------------------------
# JOIN combines rows from two or more tables based on a related column
# INNER JOIN → Only matching rows from both tables
# LEFT JOIN  → All rows from left table + matching from right

print("""
╔══════════════════════════════════════════════════════════════════════╗
║  QUERY 7: JOIN - Combine Tables                                      ║
╠══════════════════════════════════════════════════════════════════════╣
║  JOIN combines rows from two tables based on a related column        ║
║                                                                      ║
║  INNER JOIN → Only rows that exist in BOTH tables                    ║
║  LEFT JOIN  → All rows from left table, matching from right          ║
║  RIGHT JOIN → All rows from right table, matching from left          ║
╚══════════════════════════════════════════════════════════════════════╝
""")

# First, create a lookup table for region managers
region_managers = pd.DataFrame({
    'Region': ['West', 'East', 'Central', 'South'],
    'Manager': ['Sarah Johnson', 'Mike Chen', 'Lisa Rodriguez', 'David Park'],
    'Target_Sales': [15000000, 14000000, 13000000, 13500000]
})
region_managers.to_sql('region_managers', conn, if_exists='replace', index=False)
print("\n✅ Created 'region_managers' lookup table")

q7 = run_sql("""
SELECT 
    s.Region,
    rm.Manager,
    rm.Target_Sales,
    SUM(s.Sales) as Actual_Sales,
    ROUND((SUM(s.Sales) / rm.Target_Sales) * 100, 2) as Achievement_Pct
FROM sales s
INNER JOIN region_managers rm ON s.Region = rm.Region
GROUP BY s.Region, rm.Manager, rm.Target_Sales
ORDER BY Actual_Sales DESC
""", "JOIN: Sales performance vs targets by Region Manager")


# ==============================================================================
# PART 3: ADVANCED SQL (Day 9-10)
# ==============================================================================

print("\n" + "=" * 70)
print("PART 3: ADVANCED SQL QUERIES")
print("=" * 70)

# -----------------------------------------------------------------------------
# QUERY 8: Subqueries
# -----------------------------------------------------------------------------
# A subquery is a query INSIDE another query
# Think of it as: "First find the average, then show me everyone above it"

print("""
╔══════════════════════════════════════════════════════════════════════╗
║  QUERY 8: Subqueries                                                 ║
╠══════════════════════════════════════════════════════════════════════╣
║  A subquery is a query inside another query                          ║
║  The inner query runs first, then the outer query uses its result    ║
╚══════════════════════════════════════════════════════════════════════╝
""")

q8 = run_sql("""
SELECT 
    Order_ID,
    Customer_Name,
    Category,
    Sales,
    Profit
FROM sales
WHERE Sales > (SELECT AVG(Sales) FROM sales)
ORDER BY Sales DESC
LIMIT 10
""", "Subquery: Orders with Sales above average ($5,931)")


# -----------------------------------------------------------------------------
# QUERY 9: CTEs (Common Table Expressions)
# -----------------------------------------------------------------------------
# CTE = "Create a temporary result set that you can reference"
# WITH temp_table AS (SELECT ...) → SELECT * FROM temp_table
# Benefits: Makes complex queries easier to read and debug

print("""
╔══════════════════════════════════════════════════════════════════════╗
║  QUERY 9: CTEs (WITH clause)                                         ║
╠══════════════════════════════════════════════════════════════════════╣
║  CTE creates a temporary table that exists only for this query       ║
║  Makes complex queries easier to read and debug                      ║
║                                                                      ║
║  Syntax:                                                             ║
║  WITH temp_name AS (SELECT ...)                                      ║
║  SELECT * FROM temp_name                                             ║
╚══════════════════════════════════════════════════════════════════════╝
""")

q9 = run_sql("""
WITH monthly_summary AS (
    SELECT 
        Order_Year,
        Order_Month,
        Order_Month_Name,
        COUNT(*) as Total_Orders,
        SUM(Sales) as Total_Sales,
        SUM(Profit) as Total_Profit
    FROM sales
    GROUP BY Order_Year, Order_Month, Order_Month_Name
)
SELECT 
    Order_Year,
    Order_Month_Name,
    Total_Orders,
    ROUND(Total_Sales, 2) as Total_Sales,
    ROUND(Total_Profit, 2) as Total_Profit,
    ROUND((Total_Profit / Total_Sales) * 100, 2) as Profit_Margin_Pct
FROM monthly_summary
ORDER BY Total_Sales DESC
LIMIT 10
""", "CTE: Top 10 months by sales")


# -----------------------------------------------------------------------------
# QUERY 10: Window Functions
# -----------------------------------------------------------------------------
# Window functions perform calculations across a set of rows
# ROW_NUMBER() → Rank rows (1, 2, 3...)
# RANK()       → Rank with ties (1, 2, 2, 4...)
# LAG()        → Get value from previous row

print("""
╔══════════════════════════════════════════════════════════════════════╗
║  QUERY 10: Window Functions                                          ║
╠══════════════════════════════════════════════════════════════════════╣
║  Window functions calculate across a set of related rows             ║
║                                                                      ║
║  ROW_NUMBER() → Assign unique number to each row (1,2,3...)         ║
║  RANK()       → Rank with ties (1,2,2,4...)                         ║
║  LAG(col, n)  → Get value from n rows before                        ║
║                                                                      ║
║  OVER (PARTITION BY ... ORDER BY ...)                                ║
║  → "Do this calculation within each group, ordered by..."           ║
╚══════════════════════════════════════════════════════════════════════╝
""")

q10 = run_sql("""
SELECT * FROM (
    SELECT 
        Order_ID,
        Customer_Name,
        Category,
        Sales,
        Profit,
        ROW_NUMBER() OVER (PARTITION BY Category ORDER BY Sales DESC) as Rank_in_Category
    FROM sales
) ranked
WHERE Rank_in_Category <= 3
ORDER BY Category, Rank_in_Category
""", "Window Function: Top 3 sales in each category")


