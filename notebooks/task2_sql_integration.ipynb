ax.set_title('Q1: Top 5 Products by Sales', fontweight='bold', fontsize=14)
ax.invert_yaxis()
for i, v in enumerate(q1_business['Total_Sales']):
    ax.text(v + 5000, i, f'${v:,.0f}', va='center', fontweight='bold')
plt.tight_layout()
plt.savefig('sql_q1_top_products.png', dpi=150, bbox_inches='tight')
plt.show()
print("✅ Chart saved: sql_q1_top_products.png")


# -----------------------------------------------------------------------------
# BUSINESS QUESTION 2: Monthly Sales Trend
# -----------------------------------------------------------------------------
print("""
┌──────────────────────────────────────────────────────────────────────┐
│  Q2: What is the monthly sales trend?                                │
│  Purpose: Identify seasonal patterns and growth trends               │
└──────────────────────────────────────────────────────────────────────┘
""")

q2_business = pd.read_sql("""
SELECT 
    Order_Year || '-' || printf('%02d', Order_Month) as Year_Month,
    Order_Year,
    Order_Month,
    Order_Month_Name,
    SUM(Sales) as Total_Sales,
    SUM(Profit) as Total_Profit,
    COUNT(*) as Order_Count
FROM sales
GROUP BY Order_Year, Order_Month, Order_Month_Name
ORDER BY Order_Year, Order_Month
""", conn)

print(q2_business[['Year_Month', 'Total_Sales', 'Total_Profit', 'Order_Count']].head(10).to_string(index=False))
print(f"\n... showing {len(q2_business)} total months")

# Visualize
fig, ax = plt.subplots(figsize=(14, 5))
ax.plot(q2_business['Year_Month'], q2_business['Total_Sales'], marker='o', linewidth=2, color='#E74C3C')
ax.fill_between(range(len(q2_business)), q2_business['Total_Sales'], alpha=0.2, color='#E74C3C')
ax.set_xlabel('Year-Month')
ax.set_ylabel('Total Sales ($)')
ax.set_title('Q2: Monthly Sales Trend (2014-2017)', fontweight='bold', fontsize=14)
ax.tick_params(axis='x', rotation=45)
ax.set_xticks(range(0, len(q2_business), 6))
ax.set_xticklabels(q2_business['Year_Month'].iloc[::6])
ax.grid(True, alpha=0.3)
plt.tight_layout()
plt.savefig('sql_q2_monthly_trend.png', dpi=150, bbox_inches='tight')
plt.show()
print("✅ Chart saved: sql_q2_monthly_trend.png")


# -----------------------------------------------------------------------------
# BUSINESS QUESTION 3: Customer Segmentation by Spend
# -----------------------------------------------------------------------------
print("""
┌──────────────────────────────────────────────────────────────────────┐
│  Q3: How are customers segmented by their spending?                  │
│  Purpose: Identify VIP customers vs regular customers                │
└──────────────────────────────────────────────────────────────────────┘
""")

q3_business = pd.read_sql("""
