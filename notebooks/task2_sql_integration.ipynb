# -----------------------------------------------------------------------------
# BUSINESS QUESTION 4: Regional Performance vs Targets
# -----------------------------------------------------------------------------
print("""
┌──────────────────────────────────────────────────────────────────────┐
│  Q4: How are regions performing against their sales targets?         │
│  Purpose: Identify which regions need attention                      │
└──────────────────────────────────────────────────────────────────────┘
""")

q4_business = pd.read_sql("""
SELECT 
    s.Region,
    rm.Manager,
    rm.Target_Sales,
    SUM(s.Sales) as Actual_Sales,
    SUM(s.Profit) as Total_Profit,
    ROUND((SUM(s.Sales) / rm.Target_Sales) * 100, 2) as Achievement_Pct
FROM sales s
INNER JOIN region_managers rm ON s.Region = rm.Region
GROUP BY s.Region, rm.Manager, rm.Target_Sales
ORDER BY Achievement_Pct DESC
""", conn)

print(q4_business.to_string(index=False))

# Visualize
fig, ax = plt.subplots(figsize=(10, 6))
x = range(len(q4_business))
width = 0.35
ax.bar([i - width/2 for i in x], q4_business['Target_Sales'], width, label='Target', color='#3498DB', alpha=0.7)
ax.bar([i + width/2 for i in x], q4_business['Actual_Sales'], width, label='Actual', color='#2ECC71', alpha=0.7)
ax.set_xlabel('Region')
ax.set_ylabel('Sales ($)')
ax.set_title('Q4: Regional Performance vs Targets', fontweight='bold', fontsize=14)
ax.set_xticks(x)
ax.set_xticklabels(q4_business['Region'])
ax.legend()
for i, v in enumerate(q4_business['Achievement_Pct']):
    ax.text(i, max(q4_business['Target_Sales'].iloc[i], q4_business['Actual_Sales'].iloc[i]) + 200000, 
            f'{v}%', ha='center', fontweight='bold')
plt.tight_layout()
plt.savefig('sql_q4_regional_targets.png', dpi=150, bbox_inches='tight')
plt.show()
print("✅ Chart saved: sql_q4_regional_targets.png")


# -----------------------------------------------------------------------------
# BUSINESS QUESTION 5: Profit Margin by Sub-Category
# -----------------------------------------------------------------------------
print("""
┌──────────────────────────────────────────────────────────────────────┐
│  Q5: Which sub-categories have the best/worst profit margins?        │
│  Purpose: Optimize pricing strategy                                  │
└──────────────────────────────────────────────────────────────────────┘
""")

q5_business = pd.read_sql("""
SELECT 
    Category,
    Sub_Category,
    SUM(Sales) as Total_Sales,
    SUM(Profit) as Total_Profit,
    ROUND((SUM(Profit) / SUM(Sales)) * 100, 2) as Profit_Margin_Pct,
    COUNT(*) as Order_Count
FROM sales
GROUP BY Category, Sub_Category
ORDER BY Profit_Margin_Pct DESC
""", conn)

print(q5_business.to_string(index=False))

# Visualize
fig, ax = plt.subplots(figsize=(12, 8))
colors = ['#2ECC71' if v > 0 else '#E74C3C' for v in q5_business['Profit_Margin_Pct']]
ax.barh(q5_business['Sub_Category'], q5_business['Profit_Margin_Pct'], color=colors)
ax.set_xlabel('Profit Margin (%)')
ax.set_title('Q5: Profit Margin by Sub-Category', fontweight='bold', fontsize=14)
ax.axvline(x=0, color='black', linestyle='-', linewidth=0.5)
ax.invert_yaxis()
plt.tight_layout()
plt.savefig('sql_q5_profit_margin.png', dpi=150, bbox_inches='tight')
plt.show()
print("✅ Chart saved: sql_q5_profit_margin.png")


# -----------------------------------------------------------------------------
# BUSINESS QUESTION 6: Discount Impact on Profitability
# -----------------------------------------------------------------------------
print("""
┌──────────────────────────────────────────────────────────────────────┐
│  Q6: How do discounts affect profitability?                          │
│  Purpose: Evaluate discount strategy effectiveness                   │
└──────────────────────────────────────────────────────────────────────┘
""")

q6_business = pd.read_sql("""
SELECT 
    CASE 
        WHEN Discount = 0 THEN 'No Discount'
        WHEN Discount <= 0.1 THEN 'Low Discount (1-10%)'
        WHEN Discount <= 0.2 THEN 'Medium Discount (11-20%)'
        ELSE 'High Discount (>20%)'
    END as Discount_Level,
    COUNT(*) as Order_Count,
    AVG(Sales) as Avg_Sales,
    AVG(Profit) as Avg_Profit,
    SUM(Profit) as Total_Profit
FROM sales
GROUP BY Discount_Level
ORDER BY Avg_Profit DESC
""", conn)

print(q6_business.to_string(index=False))

# Visualize
fig, ax = plt.subplots(figsize=(10, 6))
colors = ['#2ECC71', '#F1C40F', '#E67E22', '#E74C3C']
ax.bar(q6_business['Discount_Level'], q6_business['Avg_Profit'], color=colors)
ax.set_ylabel('Average Profit ($)')
ax.set_title('Q6: Average Profit by Discount Level', fontweight='bold', fontsize=14)
ax.tick_params(axis='x', rotation=15)
for i, v in enumerate(q6_business['Avg_Profit']):
    ax.text(i, v + 5, f'${v:.2f}', ha='center', fontweight='bold')
plt.tight_layout()
plt.savefig('sql_q6_discount_impact.png', dpi=150, bbox_inches='tight')
plt.show()
print("✅ Chart saved: sql_q6_discount_impact.png")


