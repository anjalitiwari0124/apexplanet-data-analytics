# Create a function that can be reused for common queries
def get_sales_summary(by_column='Category'):
    """
    Get sales summary grouped by any column.

    Parameters:
        by_column (str): Column to group by (e.g., 'Category', 'Region', 'Segment')

    Returns:
        DataFrame: Summary statistics
    """
    query = f"""
    SELECT 
        {by_column},
        COUNT(*) as Total_Orders,
        SUM(Sales) as Total_Sales,
        AVG(Sales) as Avg_Sales,
        SUM(Profit) as Total_Profit,
        AVG(Profit) as Avg_Profit,
        ROUND((SUM(Profit) / SUM(Sales)) * 100, 2) as Profit_Margin_Pct
    FROM sales
    GROUP BY {by_column}
    ORDER BY Total_Sales DESC
    """
    return pd.read_sql(query, conn)

# Test the utility function
print("\n📊 Sales Summary by Region:")
print(get_sales_summary('Region').to_string(index=False))

print("\n📊 Sales Summary by Segment:")
print(get_sales_summary('Segment').to_string(index=False))

print("\n✅ Reusable utility function 'get_sales_summary()' created!")
print("   Usage: get_sales_summary('Category') or get_sales_summary('Region')")


